# .env.example - Copy to .env and fill in your values
# NEVER commit .env to Git!

# ===== Search & Information =====
# Tavily Search API
TAVILY_API_KEY=tvly-your_key_here

# ===== Maps & Weather =====
# QWeather (HeFeng) API
QWEATHER_API_KEY=your_weather_key
QWEATHER_HOST=n352qcggnq.re.qweatherapi.com

# Amap (Gaode) API
AMAP_API_KEY=your_amap_key

# ===== Academic & Research =====
# BioMCP (optional, uses public APIs)
# BIOMCP_API_KEY=

# ===== Development =====
# GitHub Personal Access Token
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_token_here

# ModelScope AI Platform
MODELSCOPE_API_TOKEN=your_modelscope_token

# ===== Document Processing =====
# (Most tools don't need API keys)

# ===== Feishu/Lark (Optional) =====
# FEISHU_APP_ID=cli_xxx
# FEISHU_APP_SECRET=your_secret
# FEISHU_USER_OPEN_ID=ou_xxx

# ===== AI Services (Optional) =====
# Image Recognition OCR Service
IMAGE_RECOGNITION_API_URL=https://ai.cnortles.top/v1/chat/completions
IMAGE_RECOGNITION_API_KEY=sk-your_key_here
IMAGE_RECOGNITION_MODEL=PaddlePaddle/PaddleOCR-VL-1.5

# OpenAI Compatible TTS
# OPENAI_COMPAT_TTS_API_KEY=sk-your_key
